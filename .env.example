# ----------------------------------------------------------------------------
# Meritia — local environment
#
# Copy this file to `.env.local` and fill in values. Do NOT commit `.env.local`.
# ----------------------------------------------------------------------------

# Postgres connection string. Create an empty DB and run `npm run db:push`
# against it before starting the app.
DATABASE_URL=postgresql://user:password@localhost:5432/meritia

# NextAuth — cryptographic secret + canonical host.
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=REPLACE_ME

# Cognito — admin sign-in. Create a Cognito user pool with PKCE and either a
# public client (no secret) or adjust src/lib/auth.ts to pass the client secret.
COGNITO_CLIENT_ID=
COGNITO_ISSUER=https://cognito-idp.<region>.amazonaws.com/<pool-id>

# Anthropic — either provide the key directly here (simplest) OR set
# SECRET_ARN + APP_REGION so Meritia fetches the key from AWS Secrets Manager
# at runtime (production path). If both are set, ANTHROPIC_API_KEY wins.
ANTHROPIC_API_KEY=
APP_REGION=eu-west-1
SECRET_ARN=

# Optional overrides.
# RECRUIT_CLAUDE_MODEL=claude-sonnet-4-5
# RECRUIT_MAX_TOKENS=1500
